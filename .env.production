# Production Environment Variables Template
# Copy this and fill in your actual values in Render/Vercel dashboards
# DO NOT commit this file with real secrets!

# ============================================================================
# RENDER BACKEND PRODUCTION ENV VARS
# ============================================================================

# Environment
ENV=production

# Database (auto-set by Render from DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/vireon

# Redis (auto-set by Render from Redis service)
REDIS_URL=redis://user:password@host:6379/0

# Security
SECRET_KEY=your-very-long-random-secure-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - Your Vercel frontend URL
ALLOWED_ORIGINS=https://your-domain.vercel.app

# LLM APIs
GROQ_API_KEY=gsk_xxxxx  # From https://console.groq.com
OPENAI_API_KEY=sk-xxxxx  # Optional
USE_LOCAL_LLM=false

# Merge.dev Integration (Optional)
MERGE_API_KEY=your_merge_key_here
MERGE_SECRET_KEY=your_merge_secret_here
MERGE_LINKED_ACCOUNT_TOKEN=your_token_here
DATA_SOURCE=merge  # or "erpnext"

# OpenRouter (Optional)
OPENROUTER_API_KEY=your_key_here

# ERPNext Integration (Optional)
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=your_api_key
ERPNEXT_API_SECRET=your_api_secret
ERPNEXT_SITE_NAME=your_site_name

# Startup Configuration
STARTUP_MAX_RETRIES=15
STARTUP_RETRY_DELAY_SECONDS=2
STRICT_STARTUP_CHECKS=true
REQUIRE_REDIS_FOR_READINESS=true
REDIS_HEALTHCHECK_TIMEOUT=1.5

# Company Information (from config.py)
COMPANY_NAME=SeedlingLabs
COMPANY_LEGAL_NAME=SeedlingLabs India Private Limited
COMPANY_CIN=U72900KA2024PTC185432

# ============================================================================
# VERCEL FRONTEND PRODUCTION ENV VARS
# ============================================================================

# Backend API URL - points to your Render backend
NEXT_PUBLIC_API_URL=https://vireon-backend.onrender.com

# Optional: Analytics/Monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_GA_ID=G-XXXXXX

# ============================================================================
# HOW TO SET THESE IN RENDER
# ============================================================================
# 1. Go to Render Dashboard → vireon-backend → Environment
# 2. Click "Environment Variables"
# 3. Add each variable as a separate entry
# 4. Set Scope to "all" for most variables
# 5. Click "Save"
# 6. Render will automatically redeploy

# ============================================================================
# HOW TO SET THESE IN VERCEL
# ============================================================================
# 1. Go to Vercel Dashboard → Your Project → Settings
# 2. Click "Environment Variables"
# 3. Add NEXT_PUBLIC_API_URL with your Render backend URL
# 4. Click "Save"
# 5. Go to Deployments and "Redeploy" to apply changes

# ============================================================================
# GENERATING A SECURE SECRET_KEY
# ============================================================================
# Run this Python command:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# - Never commit real secrets to git
# - Use environment variables for all sensitive data
# - Rotate API keys regularly
# - Monitor API key usage
# - Enable IP whitelisting where possible
# - Use HTTPS only (auto on Render and Vercel)
# - Keep dependencies updated
# - Monitor logs for security issues
