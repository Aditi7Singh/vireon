# MERGE.DEV PRODUCTION INTEGRATION
# ============================================================
# Merge.dev unified accounting API credentials
# https://docs.merge.dev/accounting/overview/

# Merge.dev API key
# Get from: https://app.merge.dev/settings/api
MERGE_API_KEY=your_merge_api_key_here

# Linked account token for specific customer's accounting system
# Generated when you link their QuickBooks/Xero account in Merge dashboard
MERGE_ACCOUNT_TOKEN=your_account_token_here

# Data source selection (development vs production)
# Options: "erpnext" (simulator) or "merge" (production QuickBooks/Xero/Stripe)
# Default: "erpnext"
# To switch to production: DATA_SOURCE=merge
DATA_SOURCE=erpnext

# ERPNEXT SIMULATOR (Development)
# ============================================================
# Keep these for development/testing

# ERPNext instance URL
ERPNEXT_URL=http://localhost:8000

# ERPNext API credentials
ERPNEXT_API_KEY=my_api_key
ERPNEXT_API_SECRET=my_api_secret

# ERPNext site name (tenant)
ERPNEXT_SITE_NAME=sagefi.localhost

# DATABASE
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/vireon

# CELERY
# ============================================================
# Message broker for task queue
CELERY_BROKER_URL=redis://localhost:6379/0

# Result backend for async task results
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM CONFIGURATION
# ============================================================
USE_LOCAL_LLM=false

# Groq API key for remote LLM inference
GROQ_API_KEY=your_groq_api_key

# Groq models to use
GROQ_FAST_MODEL=mixtral-8x7b-32768
GROQ_THINK_MODEL=mixtral-8x7b-32768

# APP SETTINGS
# ============================================================
COMPANY_NAME=SageInc
SESSION_DB_PATH=./session_db

# ENVIRONMENT
# ============================================================
ENV=development
