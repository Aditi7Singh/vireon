# Environment Configuration
# =====================
# Vireon - AI Financial Copilot

# Groq API (free, get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Backend API URL
BACKEND_URL=http://localhost:8000

# Use local Ollama instead of Groq (set to "true" for privacy mode)
USE_LOCAL_LLM=false

# Ollama Configuration (if USE_LOCAL_LLM=true)
OLLAMA_BASE_URL=http://localhost:11434

# Company Name
COMPANY_NAME=SeedlingLabs

# Session Database Path
SESSION_DB_PATH=./data/sessions.db

# Redis URL (for Celery)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL Database URL (for alerts)
DATABASE_URL=sqlite:///./vireon.db

# Merge.dev Configuration (for production data)
MERGE_API_KEY=your_merge_api_key_here
MERGE_SECRET_KEY=your_merge_secret_key_here
MERGE_LINKED_ACCOUNT_TOKEN=your_linked_account_token_here
DATA_SOURCE=merge  # or "erpnext" for ERPNext

# OpenRouter (future production swap)
OPENROUTER_API_KEY=your_openrouter_api_key_here
