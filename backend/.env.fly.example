# =========================================
# Fly.io Production Environment Variables
# =========================================
# 
# Setup Instructions:
# 1. Copy this file to .env on the Fly.io dashboard
#    OR set secrets via: flyctl secrets set KEY=VALUE
# 2. Run: flyctl secrets set-from-file .env.fly.example
# 
# Free tier note: Scale to zero means cold starts (~5-10s)
# Set min_machines_running = 1 in fly.toml to avoid cold starts

# ==============
# CORE SETTINGS
# ==============
ENVIRONMENT=production
BACKEND_URL=https://vireon-backend.fly.dev
PORT=8000

# =================
# DATABASE (Postgres)
# =================
# Option A: Use Fly.io Postgres (recommended)
# Run: flyctl postgres create --name vireon-db --initial-cluster-size 1 --vm-size shared-cpu-1x --volume-size 1
# Then: flyctl postgres attach vireon-db --app vireon-backend
# This sets DATABASE_URL automatically

# Option B: External Postgres (supabase, AWS RDS, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/vireon

# =================
# REDIS (For Celery)
# =================
# Option A: Use Upstash Redis (serverless, free tier)
# REDIS_URL=redis://default:password@region.upstash.io:6379/0

# Option B: Fly.io Redis (run alongside)
# REDIS_URL=redis://redis.internal:6379/0

# Option C: Local (not recommended for production)
# REDIS_URL=redis://localhost:6379/0

# =============
# LLM PROVIDER
# =============
# Option A: Groq (recommended - free, fast)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Option B: OpenAI
# OPENAI_API_KEY=sk-your-openai-key

# Option C: Local Ollama (requires separate Ollama deployment)
# USE_LOCAL_LLM=true
# OLLAMA_BASE_URL=http://ollama-service:11434
# OLLAMA_MODEL_FAST=llama3.1:8b
# OLLAMA_MODEL_THINK=qwen2.5:14b

# Use Groq by default
USE_LOCAL_LLM=false

# =============
# CORS SETTINGS
# =============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://vireon-frontend.vercel.app,https://your-domain.com,http://localhost:3000

# =================
# COMPANY SETTINGS
# =================
COMPANY_NAME=Vireon

# =================
# SESSION STORAGE
# =================
# For production, use Redis or database-backed sessions
SESSION_DB_PATH=./data/sessions.db

# =================
# SECRET KEY (for JWT)
# =================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-32-byte-secret-key-generated-with-openssl

# =================
# EMAIL (SMTP)
# =================
# For sending alerts and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=vireon-alerts@gmail.com

# =================
# PLAID (Bank Integration)
# =================
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox  # or production

# =================
# MERGE (ERP Sync)
# =================
MERGE_API_KEY=your_merge_api_key
MERGE_SECRET_KEY=your_merge_secret_key

# =================
# LOGGING
# =================
LOG_LEVEL=info  # debug, info, warning, error

# =================
# MONITORING
# =================
# For production monitoring
# SENTRY_DSN=your-sentry-dsn
