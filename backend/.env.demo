# ── Vireon Demo Environment ──────────────────────────────────────────────────
# Copy to backend/.env before running demo.sh
# Replace GROQ_API_KEY to enable the AI chat agent.
# All analytics, dashboards, and financial features work without an AI key.

# Database (Docker Compose sets this automatically in demo mode)
DATABASE_URL=postgresql://vireon:vireon123@localhost:5433/vireon_demo

# Cache
REDIS_URL=redis://localhost:6379/0

# Demo flag — disables external ERP sync, uses seeded data
DEMO_MODE=true
COMPANY_NAME=Orchard Analytics Inc.
DATA_SOURCE=demo

# Backend URL
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AI (optional — analytics work without this; chat agent requires a real key)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434

# Email alerts (demo uses console logging if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
